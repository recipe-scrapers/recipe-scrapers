  "description": "This baked halibut recipe is quick, easy and so flavorful! The garlic butter sauce adds so much flavor to the flaky fish. This halibut is great for holidays, birthdays, and more!",
  "host": "organicallyaddison.com",
  "image": "https://organicallyaddison.com/wp-content/uploads/2022/05/2022-05-07_19-11-48_910-2022-05-08T17_48_13.449.jpeg",
  "ingredients": [
    {
      "name": null,
      "items": [
        {
          "value": "1 pound halibut fillet"
        },
        {
          "value": "2 tbsp melted butter"
        },
        {
          "value": "1 tsp minced garlic"
        },
        {
          "value": "¼ tsp paprika"
        },
        {
          "value": "½ tsp sea salt"
        },
        {
          "value": "½ tsp black pepper"
        },
        {
          "value": "sliced lemon"
        },
        {
          "value": "chopped parsley"
        }
      ]
    }
  ],
  "instructions": [
    {
      "name": null,
      "items": [
        {
          "value": "First, preheat oven to 400 degrees Fahrenheit."
        },
        {
          "value": "Place halibut in baking dish."
        },
        {
          "value": "In a small bowl, combine melted butter, minced garlic, paprika, sea salt and black pepper. Pour this mixture over halibut."
        },
        {
          "value": "Bake for 12 to 13 minutes or until fish is opaque and no longer transparent."
        },
        {
          "value": "Finally, remove from oven. Garnish with sliced lemon and chopped parsley if desired."
        }
      ]
    }
  ],
