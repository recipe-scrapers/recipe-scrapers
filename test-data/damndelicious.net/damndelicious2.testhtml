us.net\/","name":"Damn Delicious Food Recipes","description":"Simple ingredients. Elegant dishes.","publisher":{"@id":"https:\/\/damndelicious.net\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/damndelicious.net\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/damndelicious.net\/#organization","name":"Damn Delicious","url":"https:\/\/damndelicious.net\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/damndelicious.net\/#\/schema\/logo\/image\/","url":"https:\/\/damndelicious.net\/wp-content\/uploads\/2022\/08\/DDLogo.png","contentUrl":"https:\/\/damndelicious.net\/wp-content\/uploads\/2022\/08\/DDLogo.png","width":640,"height":853,"caption":"Damn Delicious"},"image":{"@id":"https:\/\/damndelicious.net\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/damndeliciousblog","https:\/\/www.instagram.com\/damn_delicious\/"]},{"@type":"Person","@id":"https:\/\/damndelicious.net\/#\/schema\/person\/0580fef3f191728c69dace28d2fac9ff","name":"Chungah","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/10524848b45fe7909c8148d8bf9e7a0e3726d514b29b95c8428148b2f01d4798?s=96&d=blank&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/10524848b45fe7909c8148d8bf9e7a0e3726d514b29b95c8428148b2f01d4798?s=96&d=blank&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/10524848b45fe7909c8148d8bf9e7a0e3726d514b29b95c8428148b2f01d4798?s=96&d=blank&r=g","caption":"Chungah"},"description":"Chungah Rhee is the founder of Damn Delicious, a website created in 2011 featuring quick and easy meals. Chungah and her recipes are regularly featured in major media such as People, TODAY, and Bon Appetit, among others. Today, Chungah cooks nonstop alongside her two favorite corgi assistants, Butters and Cartman.","sameAs":["https:\/\/damndelicious.net\/about-me\/","https:\/\/www.facebook.com\/damndeliciousblog","https:\/\/www.instagram.com\/damn_delicious\/","https:\/\/x.com\/@damn_delicious"]},{"@type":"Question","@id":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1715620917648","position":1,"url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1715620917648","name":"Is this guacamole spicy?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"The jalapeño will add subtle heat to the guacamole. For mild flavors, remove the seeds and membranes, or skip the jalapeño altogether.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770839697643","position":2,"url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770839697643","name":"I am not a fan of cilantro. What can I use to substitute cilantro in guacamole?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Flat leaf parsley can be substituted 1:1 for the cilantro, although parsley is slightly milder and less pungent than cilantro.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770839324878","position":3,"url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770839324878","name":"Do I have to add the tomato?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"This is purely based on personal preference, although purists are fully against adding tomatoes to guacamole, arguing that it adds excess moisture and can serve as a filler. But we love incorporating tomatoes for its fresh, bright flavors, adding a nice bite and yielding a chunkier guacamole dip.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770839548061","position":4,"url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770839548061","name":"What can I serve guacamole with?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Guacamole is incredibly versatile, and can be served with tortilla chips, crackers and veggie dippers (carrots, celery sticks, bell peppers, cucumbers, jicama), or utilized as a topping for tacos, quesadillas, fajitas, nachos, burgers, sandwiches, wraps and so much more.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Question","@id":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770823142617","position":5,"url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#faq-question-1770823142617","name":"Can I make guacamole ahead of time?","answerCount":1,"acceptedAnswer":{"@type":"Answer","text":"Yes! Guacamole can be made up to 1 day in advance, pressing plastic wrap directly on top (to remove any air and prevent from browning) and placed in the fridge.","inLanguage":"en-US"},"inLanguage":"en-US"},{"@type":"Recipe","name":"The Best Guacamole","author":{"@id":"https:\/\/damndelicious.net\/#\/schema\/person\/0580fef3f191728c69dace28d2fac9ff"},"description":"The only guacamole recipe you&#039;ll need, using ripe avocados, onion, cilantro, lime zest + juice, jalapeño, garlic + tomato. So fresh, so good!","datePublished":"2026-04-17T21:00:00+00:00","image":["https:\/\/damndelicious.net\/wp-content\/uploads\/2026\/02\/251218_DD_Guacamole_135.jpg","https:\/\/damndelicious.net\/wp-content\/uploads\/2026\/02\/251218_DD_Guacamole_135-500x500.jpg","https:\/\/damndelicious.net\/wp-content\/uploads\/2026\/02\/251218_DD_Guacamole_135-500x375.jpg","https:\/\/damndelicious.net\/wp-content\/uploads\/2026\/02\/251218_DD_Guacamole_135-480x270.jpg"],"video":{"name":"The Best Guacamole (Simple, Fresh, Restaurant-Quality)","description":"The only guacamole recipe you'll need, using ripe avocados, onion, cilantro, lime zest + juice, jalapeño, garlic + tomato. So fresh, so good!","thumbnailUrl":"https:\/\/content.jwplatform.com\/thumbs\/x3XWN8ye-720.jpg","contentUrl":"https:\/\/content.jwplatform.com\/videos\/x3XWN8ye.mp4","uploadDate":"2026-04-17T04:00:00+00:00","@type":"VideoObject"},"recipeYield":["8","8 servings"],"prepTime":"PT20M","recipeIngredient":["4 medium ripe avocados (halved, seeded and peeled)","1\/3 cup finely chopped red or white onion","1\/2 bunch fresh cilantro leaves (finely chopped)","2 teaspoons lime zest","3 tablespoons freshly squeezed lime juice","1  medium jalapeño pepper (finely diced, optional)","1 clove garlic (finely grated)","Kosher salt and freshly ground black pepper (to taste)","1  firm Roma tomato (seeded and diced, optional)"],"recipeInstructions":[{"@type":"HowToStep","text":"Place avocados in a medium bowl; using a large fork, mash until chunky or desired consistency is reached.","name":"Place avocados in a medium bowl; using a large fork, mash until chunky or desired consistency is reached.","url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#wprm-recipe-45910-step-0-0","image":"https:\/\/damndelicious.net\/wp-content\/uploads\/2015\/05\/260330_DD_guacamole_210.jpg"},{"@type":"HowToStep","text":"Stir in onion, cilantro, lime zest, lime juice, jalapeño and garlic; season with salt and pepper, to taste.","name":"Stir in onion, cilantro, lime zest, lime juice, jalapeño and garlic; season with salt and pepper, to taste.","url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#wprm-recipe-45910-step-0-1","image":"https:\/\/damndelicious.net\/wp-content\/uploads\/2015\/05\/260330_DD_guacamole_213.jpg"},{"@type":"HowToStep","text":"Stir in tomatoes, if using.","name":"Stir in tomatoes, if using.","url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#wprm-recipe-45910-step-0-2","image":"https:\/\/damndelicious.net\/wp-content\/uploads\/2015\/05\/260330_DD_guacamole_215.jpg"},{"@type":"HowToStep","text":"Serve immediately.","name":"Serve immediately.","url":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#wprm-recipe-45910-step-0-3","image":"https:\/\/damndelicious.net\/wp-content\/uploads\/2015\/05\/260330_DD_guacamole_217.jpg"}],"@id":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#recipe","isPartOf":{"@id":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/#article"},"mainEntityOfPage":"https:\/\/damndelicious.net\/2026\/04\/17\/the-best-guacamole-simple-fresh-restaurant-quality\/"}]}</script>
