        },
        {
          "value": "1/2 bunch fresh cilantro leaves (finely chopped)"
        },
        {
          "value": "2 teaspoons lime zest"
        },
        {
          "value": "3 tablespoons freshly squeezed lime juice"
        },
        {
          "value": "1 medium jalapeño pepper (finely diced, optional)"
        },
        {
          "value": "1 clove garlic (finely grated)"
        },
        {
          "value": "Kosher salt and freshly ground black pepper (to taste)"
        },
        {
          "value": "1 firm Roma tomato (seeded and diced, optional)"
        }
      ],
      "name": null
    }
  ],
  "instructions": [
    {
      "items": [
        {
          "value": "Place avocados in a medium bowl; using a large fork, mash until chunky or desired consistency is reached."
        },
        {
          "value": "Stir in onion, cilantro, lime zest, lime juice, jalapeño and garlic; season with salt and pepper, to taste."
        },
        {
          "value": "Stir in tomatoes, if using."
        },
        {
          "value": "Serve immediately."
        }
