  "ingredients": [
    {
      "name": null,
      "items": [
        {
          "value": "1 onion finely chopped"
        },
        {
          "value": "500g beef mince"
        },
        {
          "value": "1 cup water"
        },
        {
          "value": "2 beef stock cubes"
        },
        {
          "value": "1/4 cup tomato sauce"
        },
        {
          "value": "2 tsp Worcestershire sauce"
        },
        {
          "value": "1 pinch salt and pepper *to taste"
        },
        {
          "value": "3 tbs plain flour"
        },
        {
          "value": "1 sheet shortcrust pastry"
        },
        {
          "value": "1 sheet puff pastry"
        },
        {
          "value": "1 egg to glaze"
        }
      ]
    }
  ],
  "instructions": [
    {
      "name": null,
      "items": [
        {
          "value": "Cook meat and onion until meat is well browned."
        },
        {
          "value": "Add ¾ cup water, stock cubes, sauces and seasonings."
        },
        {
          "value": "Bring to the boil and simmer for 15 minutes."
        },
        {
          "value": "Blend flour and the remaining water, add to meat, bring to the boil and simmer for 5 minutes. Cool."
        },
        {
          "value": "Line a pie plate with the shortcrust pastry."
        },
        {
          "value": "Spoon in the cooled meat mixture. Moisten edges of pastry with water."
        },
        {
          "value": "Top with puff pastry, pressing down to seal the edges, trim and glaze with egg."
        },
        {
          "value": "Bake at 230C for 15 minutes. Reduce heat to 190C and bake for a futher 25 minutes until golden."
        }
      ]
    }
  ],
