  "instructions": [
    {
      "name": null,
      "items": [
        {
          "value": "Place a frying pan over high heat and add 2-3 tablespoons olive oil."
        },
        {
          "value": "Cut the chicken into 2-3 cm pieces and add them into a bowl. Add salt, pepper, the flour, and mix."
        },
        {
          "value": "Transfer the chicken to the hot pan and sauté for 3-4 minutes until golden."
        },
        {
          "value": "Place a pot over high heat and add 2 tablespoons olive oil."
        },
        {
          "value": "Finely chop the onions and the garlic, add them to the pot, and sauté."
        },
        {
          "value": "Add the artichokes, the chicken, and deglaze the pot with the wine."
        },
        {
          "value": "Add the lemon juice, the water, the chicken stock pot, the tarragon, and mix."
        },
        {
          "value": "Cover with the lid and simmer over medium heat for 20-25 minutes."
        },
        {
          "value": "Serve with pepper, olive oil, lemon slices, and parsley."
        }
      ]
    }
