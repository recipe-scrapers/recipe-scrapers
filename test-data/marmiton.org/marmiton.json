  "instructions": [
    {
      "name": null,
      "items": [
        {
          "value": "Coupez les tomates pelées en quartiers,"
        },
        {
          "value": "les aubergines et les courgettes en rondelles."
        },
        {
          "value": "Emincez les poivrons en lamelles"
        },
        {
          "value": "et l'oignon en rouelles."
        },
        {
          "value": "Chauffez 2 cuillères à soupe d'huile dans une poêle"
        },
        {
          "value": "et faites-y fondre les oignons et les poivrons."
        },
        {
          "value": "Lorsqu'ils sont tendres, ajoutez les tomates, l'ail haché, le thym et le laurier."
        },
        {
          "value": "Salez, poivrez et laissez mijoter doucement à couvert durant 45 minutes."
        },
        {
          "value": "Pendant ce temps, préparez les aubergines et les courgettes. Faites les cuire séparemment ou non dans l'huile d'olive pendant 15 minutes."
        },
        {
          "value": "Vérifiez la cuisson des légumes pour qu'ils ne soient plus fermes. Ajoutez les alors au mélange de tomates et prolongez la cuisson sur tout petit feu pendant 10 min."
        },
        {
          "value": "Salez et poivrez si besoin."
        }
      ]
    }
  ],
