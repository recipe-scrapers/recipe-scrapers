ill="none" stroke="#688ff4" stroke-miterlimit="10"></path><circle data-color="color-2" data-stroke="none" cx="4" cy="8" r="1" stroke="none"></circle></g></svg></span></button><button class="wprm-recipe-media-toggle wprm-toggle" data-state="off" data-recipe="85527" style="background-color: #688ff4;color: #ffffff;border-left: 1px solid #688ff4;" aria-label="Hide instruction media"><span class="wprm-recipe-icon wprm-toggle-icon wprm-toggle-icon-active"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24"><g class="nc-icon-wrapper" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1" transform="translate(0.5 0.5)" fill="#ffffff" stroke="#ffffff"><circle data-color="color-2" cx="12" cy="12" r="4" fill="none" stroke-miterlimit="10"></circle><path d="M22,8v9a2,2,0,0,1-2,2H10" fill="none" stroke="#ffffff" stroke-miterlimit="10"></path><path data-cap="butt" d="M2,17V8A2,2,0,0,1,4,6H7L9,3h6l2.4,3.6" fill="none" stroke="#ffffff" stroke-miterlimit="10" stroke-linecap="butt"></path><line data-cap="butt" data-color="color-2" x1="23" y1="1" x2="1" y2="23" fill="none" stroke-miterlimit="10" stroke-linecap="butt"></line></g></svg></span><span class="wprm-recipe-icon wprm-toggle-icon wprm-toggle-icon-inactive"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 24 24"><g class="nc-icon-wrapper" stroke-linecap="square" stroke-linejoin="miter" stroke-width="1" transform="translate(0.5 0.5)" fill="#688ff4" stroke="#688ff4"><circle data-color="color-2" cx="12" cy="12" r="4" fill="none" stroke-miterlimit="10"></circle><path d="M22,8v9a2,2,0,0,1-2,2H10" fill="none" stroke="#688ff4" stroke-miterlimit="10"></path><path data-cap="butt" d="M2,17V8A2,2,0,0,1,4,6H7L9,3h6l2.4,3.6" fill="none" stroke="#688ff4" stroke-miterlimit="10" stroke-linecap="butt"></path><line data-cap="butt" data-color="color-2" x1="23" y1="1" x2="1" y2="23" fill="none" stroke-miterlimit="10" stroke-linecap="butt"></line></g></svg></span></button></div></h3><div class="wprm-recipe-instruction-group"><ul style="--wprm-advanced-list-background: #688ff4;" class="wprm-advanced-list wprm-advanced-list-reset wprm-recipe-instructions"><li id="wprm-recipe-85527-step-0-0" class="wprm-recipe-instruction" style="list-style-type: none;"><div class="wprm-recipe-instruction-text" style="margin-bottom: 5px;"><span style="display: block;">Preheat oven to 300&deg;F</span></div></li><li id="wprm-recipe-85527-step-0-1" class="wprm-recipe-instruction" style="list-style-type: none;"><div class="wprm-recipe-instruction-text" style="margin-bottom: 5px;"><span style="display: block;">Add the melted coconut oil, maple syrup and vanilla to a small bowl or 1qt measuring cup and stir to combine.</span></div><div class="wprm-recipe-instruction-ingredients wprm-recipe-instruction-ingredients-inline wprm-block-text-faded" style="margin-top: -5px; margin-bottom: 5px;"><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-4" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">3/4 cup Coconut Oil, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-5" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">1 cup Pure Maple Syrup, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-7" data-separator="" data-both-units="0" style="margin-bottom: 5px;">1  tsp Pure Vanilla Extract</span></div></li><li id="wprm-recipe-85527-step-0-2" class="wprm-recipe-instruction" style="list-style-type: none;"><div class="wprm-recipe-instruction-text" style="margin-bottom: 5px;"><span style="display: block;">Add the oats, nuts and spices to a large bowl and stir to combine.</span></div><div class="wprm-recipe-instruction-ingredients wprm-recipe-instruction-ingredients-inline wprm-block-text-faded" style="margin-top: -5px; margin-bottom: 5px;"><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-0" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">10 cups Old Fashioned Rolled Oats, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-1" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">1 cup Almonds, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-2" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">1 cup Pecans, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-3" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">1 cup Walnuts, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-8" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">1 tsp Cinnamon, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-9" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">1 tsp Ginger, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-10" data-separator=", " data-both-units="0" style="margin-bottom: 5px;">1 tsp Clove, </span><span class="wprm-recipe-instruction-ingredient wprm-recipe-instruction-ingredient-85527-11" data-separator="" data-both-units="0" style="margin-bottom: 5px;">1 tsp Nutmeg</span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img loading="lazy" decoding="async" width="225" height="300" src="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-1-min-225x300.jpg" class="attachment-medium size-medium" alt="oats with spices" srcset="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-1-min-225x300.jpg 225w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-1-min-768x1024.jpg 768w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-1-min-1152x1536.jpg 1152w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-1-min-1536x2048.jpg 1536w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-1-min-scaled.jpg 1920w" sizes="auto, (max-width: 225px) 100vw, 225px" data-pin-media="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-1-min.jpg"></div> </li><li id="wprm-recipe-85527-step-0-3" class="wprm-recipe-instruction" style="list-style-type: none;"><div class="wprm-recipe-instruction-text" style="margin-bottom: 5px;"><span style="display: block;">Pour the syrup mixture over the oats and mix to coat everything evenly.</span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img loading="lazy" decoding="async" width="225" height="300" src="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-3-min-225x300.jpg" class="attachment-medium size-medium" alt="granola" srcset="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-3-min-225x300.jpg 225w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-3-min-768x1024.jpg 768w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-3-min-1152x1536.jpg 1152w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-3-min-1536x2048.jpg 1536w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-3-min-scaled.jpg 1920w" sizes="auto, (max-width: 225px) 100vw, 225px" data-pin-media="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-3-min.jpg"></div> </li><li id="wprm-recipe-85527-step-0-4" class="wprm-recipe-instruction" style="list-style-type: none;"><div class="wprm-recipe-instruction-text" style="margin-bottom: 5px;"><span style="display: block;">Spread evenly on parchment lined baking sheet. It will be very full!</span></div><div class="wprm-recipe-instruction-media wprm-recipe-instruction-image"><img loading="lazy" decoding="async" width="225" height="300" src="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-4-min-225x300.jpg" class="attachment-medium size-medium" alt="" srcset="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-4-min-225x300.jpg 225w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-4-min-768x1024.jpg 768w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-4-min-1152x1536.jpg 1152w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-4-min-1536x2048.jpg 1536w, https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-4-min-scaled.jpg 1920w" sizes="auto, (max-width: 225px) 100vw, 225px" data-pin-media="https://brasspine.com/wp-content/uploads/2025/12/Holiday-Spiced-Granola-4-min.jpg"></div> </li><li id="wprm-recipe-85527-step-0-5" class="wprm-recipe-instruction" style="list-style-type: none;"><div class="wprm-recipe-instruction-text" style="margin-bottom: 5px;"><span style="display: block;">Bake for 1 hour, stirring after 30 minutes. Cool completely before serving.</span></div></li></ul></div></div>

<div id="recipe-85527-notes" class="wprm-recipe-notes-container wprm-block-text-normal"><h3 class="wprm-recipe-header wprm-recipe-notes-header wprm-block-text-uppercase wprm-align-left wprm-header-decoration-line" style="">Notes<div class="wprm-decoration-line" style="border-color: #e0e0e0;"></div></h3><div class="wprm-recipe-notes"><ol>
<li>Store in an airtight container for up to 3 weeks.</li>
<li>The granola will crisp up more as it cools, but if you want it extra crispy you can bake it for another 15-30 minutes.</li>
</ol></div></div>

