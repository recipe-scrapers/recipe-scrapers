<script type="application/ld+json"> {"@context": "https://schema.org/","@type": "Recipe", "@id": "#itr-recipe-15938", "name": "Easy Hummus (Better than Store-Bought)", "image": "https://www.inspiredtaste.net/wp-content/uploads/2019/07/The-Best-Homemade-Hummus-Recipe-1200.jpg", "author": {"@type": "Person", "name": "Joanne Gallagher", "description": "Title: Co-founder of Inspired Taste
Expertise: Alongside my husband, Adam, I develop and meticulously test our recipes, and guide you in our recipe videos. Using over 15 years of experience and my love for cooking, I aim to help you feel more confident and successful in your kitchen! My cooking advice and recipes have been featured in major food publications, including Food &amp; Wine, Simply Recipes, Chowhound, and Homes &amp; Gardens.
Background: You can learn more about the Inspired Taste story and our small but mighty team on our about page. Below, you will find my latest recipes!"}, "datePublished": "2024-05-26", "dateModified": "2026-01-05", "description": "How to make hummus with chickpeas, garlic, tahini and olive oil. This is the best hummus recipe, just read all the happy reviews. Tahini is a paste made from sesame seeds. Buy it or make it yourself. Here&#8217;s our tahini recipe, which I highly recommend for this recipe! To leave it out, add more olive oil.", "prepTime": "PT10M", "totalTime": "PT10M", "recipeYield": "6 Servings (Makes 1 1/2 cups)", "recipeCategory": "Appetizer", "recipeCuisine": "Middle Eastern", "keywords": "how to make hummus, best homemade hummus", "nutrition": {"@type": "NutritionInformation","servingSize": "1/4 cup","calories": "155","fatContent": "11g","saturatedFatContent": "1.5g","cholesterolContent": "0mg","sodiumContent": "278.3mg","carbohydrateContent": "11.8g","fiberContent": "2.9g","sugarContent": "1.8g","proteinContent": "4.5g"}, "recipeIngredient": ["1 (15-ounce) can chickpeas, drained or 1 ½ cups cooked chickpeas (250g)","¼ cup fresh lemon juice, from 1 large lemon (60ml)","¼ cup well-stirred tahini, try our tahini recipe (60ml)","1 small garlic clove, minced","2 tablespoons extra-virgin olive oil, plus more for serving (30ml)","½ teaspoon ground cumin","Salt to taste","2 to 3 tablespoons cold water or aquafaba (45ml)","Dash ground paprika, sumac, or Za&#8217;atar for serving"], "recipeInstructions": [{"@type": "HowToStep", "text": "Whip the tahini and lemon juice: In the bowl of a food processor, combine the tahini and lemon juice and process for 1 minute. Scrape the sides and bottom of the bowl, then process for 30 seconds more. This extra time helps &#8220;whip&#8221; or &#8220;cream&#8221; the tahini, making the hummus smooth and creamy."},{"@type": "HowToStep", "text": "Add olive oil and spices: Add the olive oil, minced garlic, cumin, and 1/2 teaspoon of salt to the whipped tahini and lemon juice. Process for 30 seconds, scrape the sides and bottom of the bowl, and then process for another 30 seconds or until well blended."},{"@type": "HowToStep", "text": "Add the chickpeas: Drain the chickpeas. Then add half of the chickpeas to the food processor and process for 1 minute. Scrape the sides and bottom of the bowl, then add the remaining chickpeas and process them until thick and relatively smooth, 1 to 2 minutes."},{"@type": "HowToStep", "text": "Thin with water: The hummus will likely be too thick and still have tiny bits of chickpea. To fix this, slowly add 2 to 3 tablespoons of cold water or aquafaba with the food processor turned on until you reach the perfect consistency."},{"@type": "HowToStep", "text": "To finish: Taste and adjust as needed with more salt or lemon. Serve with a drizzle of olive oil and a sprinkle of paprika, sumac, or Za&#8217;atar over the top."}], "video": {"@type": "VideoObject","name":"Easy Hummus Recipe (Better than Store-Bought)","embedUrl":"https://www.youtube.com/embed/d4soRs0ZBgE","contentUrl":"https://www.youtube.com/watch?v=d4soRs0ZBgE","thumbnailUrl":"https://i.ytimg.com/vi/d4soRs0ZBgE/maxresdefault.jpg","description":"This is my favorite hummus recipe! With a few simple tricks, you can make the best creamy, smooth homemade hummus that's way better than store-bought.","duration":"PT4M20S","uploadDate":"2024-01-10T16:24:08-08:00"},
"aggregateRating": {"@type": "AggregateRating","ratingValue": "4.9","reviewCount": "1917"}
, "review": [{ "@type": "Review", "author": [{ "@type": "Person", "name": "Tessa"}],"datePublished": "2026-02-23 18:32:55","reviewBody": "I've made this 3 times in the last 10 days. My grown kids keep asking me to make this. It doesn't last long and I also love it myself. It's much better than other homemade recipes that I have tasted.","reviewRating": {"@type": "Rating","bestRating": "5","ratingValue": "5", "worstRating": "1"}},
{ "@type": "Review", "author": [{ "@type": "Person", "name": "Cathy"}],"datePublished": "2026-02-22 18:50:00","reviewBody": "This absolutely is the best hummus recipe I have found, bar none. Turns out creamy every time. Not just better than store bought, better than any other recipe I have found. Thanks!","reviewRating": {"@type": "Rating","bestRating": "5","ratingValue": "5", "worstRating": "1"}},
{ "@type": "Review", "author": [{ "@type": "Person", "name": "S"}],"datePublished": "2026-02-22 18:18:09","reviewBody": "Great recipe! Easy to do and delicious. There is nothing like using fresh ingredients and didn't take but a few minutes to do. Thank you!","reviewRating": {"@type": "Rating","bestRating": "5","ratingValue": "5", "worstRating": "1"}},
{ "@type": "Review", "author": [{ "@type": "Person", "name": "Shannon Brinson"}],"datePublished": "2026-02-22 13:59:32","reviewBody": "Easy to follow recipe! The taste is a bit lemony for me so next time I'll use less lemon and a bit more cumin but  overall very good! Thank you!","reviewRating": {"@type": "Rating","bestRating": "5","ratingValue": "4", "worstRating": "1"}},
{ "@type": "Review", "author": [{ "@type": "Person", "name": "Julie Stewart-Clarke"}],"datePublished": "2026-02-21 10:49:07","reviewBody": "I've never made hummus before but after following this easy recipe and tasting the finished product I will definitely be making it again. Better than store bought by far. Thoroughly recommend it.","reviewRating": {"@type": "Rating","bestRating": "5","ratingValue": "5", "worstRating": "1"}},
{ "@type": "Review", "author": [{ "@type": "Person", "name": "Jeanne"}],"datePublished": "2026-02-15 17:43:09","reviewBody": "I made your tahini today and then decided to make the hummus. Both are perfect! I added a little Calabrian hot chili powder to the hummus and sprinkled more on top with some smoked paprika. Topped with a little chopped parsley for extra color. Both are fantastic recipes. My husband had a hard time putting the hummus away. Needless to say, I just ordered 5 lbs. of sesame seeds. I wonder what I'll use those for ;). Thank you!","reviewRating": {"@type": "Rating","bestRating": "5","ratingValue": "5", "worstRating": "1"}},
{ "@type": "Review", "author": [{ "@type": "Person", "name": "Paola"}],"datePublished": "2026-02-15 01:04:12","reviewBody": "Yummy recipe. Have made this a couple of times now and it's always a hit. Thank you","reviewRating": {"@type": "Rating","bestRating": "5","ratingValue": "5", "worstRating": "1"}}
]}</script>

