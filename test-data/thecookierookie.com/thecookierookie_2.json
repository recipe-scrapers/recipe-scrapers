  "instructions": [
    {
      "name": null,
      "items": [
        {
          "value": "Prep"
        },
        {
          "value": "Mix the salt, chili powder, cumin, paprika, onion powder, and black pepper together. Rub the salmon fillets with olive oil and this seasoning mix."
        },
        {
          "value": "Chill"
        },
        {
          "value": "Refrigerate for at least 30 minutes."
        },
        {
          "value": "Combine the avocado, onion, lime juice, and cilantro. Chill until serving time."
        },
        {
          "value": "Preheat the grill to medium (350-375°F)."
        },
        {
          "value": "Grill the salmon to desired doneness (about 3-4 minutes per side)."
        },
        {
          "value": "Top with avocado salsa and enjoy!"
        }
      ]
    }
