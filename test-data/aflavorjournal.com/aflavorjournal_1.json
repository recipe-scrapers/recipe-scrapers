          "value": "3 tbsp. Buttermilk"
        },
        {
          "value": "2 tbsp. Mayonnaise (best quality)"
        },
        {
          "value": "2 tbsp. Sour Cream"
        },
        {
          "value": "1 tsp. dried Minced Onion"
        },
        {
          "value": "1 tsp. dried Parsley Flakes"
        },
        {
          "value": "1/2 tsp. dried Chives"
        },
        {
          "value": "1/4 tsp. Garlic Powder"
        },
        {
          "value": "1/4 tsp. Onion Powder"
        },
        {
          "value": "1/4 tsp. dried Dill"
        },
        {
          "value": "1/4 tsp. Sea Salt"
        },
        {
          "value": "1/4 tsp. freshly cracked Black Pepper"
        }
      ]
    }
  ],
  "instructions": [
    {
      "name": null,
      "items": [
        {
          "value": "Whisk the 3 tbsp. buttermilk, 2 tbsp. mayonnaise, and 2 tbsp. sour cream together in a medium bowl."
        },
        {
          "value": "Stir in the dried herbs (1 tsp. dried minced onion, 1 tsp. dried parsley flakes, 1/2 tsp. dried chives, 1/4 tsp. each of onion powder, garlic powder, and dried dill)."
        },
        {
          "value": "Stir in a pinch each of salt and pepper, taste, and add more of either if preferred. For a thinner dressing, stir in more buttermilk (1 tsp. at a time) until the dressing is the consistency you like."
        },
        {
          "value": "Cover and chill for an hour in the refrigerator for the best flavor, or serve immediately!"
        }
      ]
    }
  ],
